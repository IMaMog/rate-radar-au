{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/refresh.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/data/snapshot.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
